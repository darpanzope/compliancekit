{
  "$schema": "https://json.schemastore.org/sarif-2.1.0-rtm.5.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Trivy",
          "version": "0.50.4",
          "informationUri": "https://github.com/aquasecurity/trivy",
          "rules": [
            {
              "id": "AVD-AWS-0107",
              "name": "aws-vpc-no-public-ingress-sgr",
              "shortDescription": {
                "text": "An ingress security group rule allows traffic from /0."
              },
              "fullDescription": {
                "text": "Opening up ports to the public internet is generally to be avoided."
              },
              "defaultConfiguration": { "level": "error" },
              "properties": { "security-severity": "9.0" },
              "helpUri": "https://avd.aquasec.com/misconfig/avd-aws-0107"
            },
            {
              "id": "AVD-AWS-0086",
              "name": "aws-s3-block-public-acls",
              "shortDescription": { "text": "S3 bucket allows public ACLs." },
              "defaultConfiguration": { "level": "error" },
              "properties": { "security-severity": "7.5" }
            },
            {
              "id": "CVE-2024-12345",
              "shortDescription": { "text": "openssl: heap-buffer-overflow in X.509 verification" },
              "defaultConfiguration": { "level": "error" },
              "properties": { "security-severity": "8.1" }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "AVD-AWS-0107",
          "level": "error",
          "message": { "text": "Security group rule allows ingress from 0.0.0.0/0 on port 22" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "infra/sg.tf" },
                "region": { "startLine": 12, "endLine": 18 }
              }
            }
          ],
          "properties": { "security-severity": "9.0" }
        },
        {
          "ruleId": "AVD-AWS-0086",
          "level": "error",
          "message": { "text": "S3 bucket 'public-bucket' allows public ACLs" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "infra/s3.tf" },
                "region": { "startLine": 4, "endLine": 7 }
              }
            }
          ],
          "properties": { "security-severity": "7.5" }
        },
        {
          "ruleId": "CVE-2024-12345",
          "level": "error",
          "message": { "text": "openssl 3.0.7 is vulnerable to CVE-2024-12345 (CVSS 8.1)" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "image://alpine:3.18.0/lib/openssl" }
              }
            }
          ],
          "properties": { "security-severity": "8.1" }
        }
      ]
    }
  ]
}
