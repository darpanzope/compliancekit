{
  "$schema": "https://json.schemastore.org/sarif-2.1.0-rtm.5.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "terrascan",
          "version": "1.18.11",
          "informationUri": "https://runterrascan.io"
        }
      },
      "results": [
        {
          "ruleId": "AC_AWS_0019",
          "level": "error",
          "message": { "text": "Security group rule allows ingress from 0.0.0.0/0 on port 22" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "aws/sg.tf" },
                "region": { "startLine": 9 }
              }
            }
          ]
        },
        {
          "ruleId": "AC_K8S_0001",
          "level": "warning",
          "message": { "text": "Container runs as root user" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "k8s/deployment.yaml" },
                "region": { "startLine": 12 }
              }
            }
          ]
        }
      ]
    }
  ]
}
